#!/usr/bin/env node
'use strict';

// pact CLI 진입점 (PACT-041, P2.6)
// 결정적 작업: 배치 계획 / 머지 게이트 / 상태 표시.
// LLM 안 거침 — 코드만.

const cmd = process.argv[2];
const args = process.argv.slice(3);

const commands = {
  batch: () => require('./cmds/batch.js')(args),
  merge: () => require('./cmds/merge.js')(args),
  status: () => require('./cmds/status.js')(args),
  slice: () => require('./cmds/slice.js')(args),
  'slice-prd': () => require('./cmds/slice-prd.js')(args),
  'split-docs': () => require('./cmds/split-docs.js')(args),
  'context-map': () => require('./cmds/context-map.js')(args),
  'context-guard': () => require('./cmds/context-guard.js')(args),
  'run-cycle': () => require('./cmds/run-cycle.js')(args),
  claim: () => require('./cmds/claim.js')(args),
  next: () => require('./cmds/next.js')(args),
  'list-locks': () => require('./cmds/list-locks.js')(args),
};

if (!cmd || !commands[cmd]) {
  console.error('Usage: pact <command>\n');
  console.error('Commands:');
  console.error('  batch       TASKS.md → .pact/batch.json (배치 계획 생성)');
  console.error('  merge       .pact/runs/*/status.json 기반 머지 게이트');
  console.error('  status      .pact/state.json + worktree 표시 (--summary/-s 한 줄)');
  console.error('  slice       TASKS.md 슬라이스 (--status, --priority, --ids, --tbd, --headers)');
  console.error('  slice-prd   PRD 섹션 추출 (--section, --sections, --headers, --refs-from)');
  console.error('  split-docs  긴 TASKS/API/DB 계약 문서를 domain shard로 분리');
  console.error('  context-map sync   docs/context-map.md Domains 표를 현재 shard 상태로 갱신');
  console.error('  context-guard      parallel 전 긴 문서/선택 컨텍스트 위험 검사');
  console.error('  run-cycle <prepare|collect> [--max=N]  /pact:parallel 결정적 작업 통합 (메인 turn 압축)');
  console.error('  claim <task_id> [<task_id>...] [--session <label>]  멀티세션에서 task 점유 (한 번에 여러)');
  console.error('  next [--all] [--json]                  현재 batch에서 미점유 task 한 개 (또는 전체)');
  console.error('  list-locks [--mine] [--session <label>] [--alive] [--json]  잡힌 lock 목록');
  process.exit(cmd ? 1 : 0);
}

(async () => {
  try {
    await commands[cmd]();
  } catch (e) {
    console.error(`pact ${cmd} 실패:`, e.message);
    process.exit(1);
  }
})();
