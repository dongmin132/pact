{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task Definition",
  "description": "TASKS.md의 각 task 블록 (planner 출력). parse-tasks.js가 검증.",
  "type": "object",
  "required": ["id", "title", "priority", "dependencies", "allowed_paths", "done_criteria", "tdd"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*-[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P1.5", "P2.5", "P2.6"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["task_id", "kind"],
            "properties": {
              "task_id": { "type": "string" },
              "kind": { "type": "string", "enum": ["complete", "contract_only"] }
            }
          }
        ]
      }
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files": {
      "type": "array",
      "maxItems": 5,
      "items": { "type": "string" }
    },
    "work": {
      "type": "array",
      "items": { "type": "string" }
    },
    "done_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "verify_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contracts": {
      "type": "object"
    },
    "tdd": {
      "type": "boolean"
    },
    "context_budget_tokens": {
      "type": "integer",
      "minimum": 1000
    },
    "prd_reference": {
      "type": ["string", "null"]
    },
    "sourcing": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["todo", "in_progress", "done", "failed", "blocked"]
    },
    "worker_model": {
      "type": "string",
      "enum": ["haiku", "sonnet", "opus"],
      "description": "C-1: 이 task 워커의 모델 분기 (선택). 미지정=spawn 기본값(sonnet). 단순·기계적 task 는 haiku 로 배치 토큰 절감."
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "loop_until": {
      "type": "object",
      "required": ["count"],
      "properties": {
        "count": { "type": "string", "minLength": 1 },
        "max_iterations": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "additionalProperties": true
}
